{
  "name": "harborline",
  "version": "0.2.0",
  "private": true,
  "description": "Harborline — clean-room top-down urban action sandbox",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -p tsconfig.json --noEmit && vite build",
    "preview": "vite preview",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint .",
    "check": "npm run typecheck && npm run lint",
    "test": "vitest run",
    "test:e2e": "playwright test",
    "verify": "npm run check && npm run test && npm run build && npm run test:e2e"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "phaser": "^3.90.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.30.1",
    "@playwright/test": "^1.53.2",
    "@types/node": "^24.0.10",
    "eslint": "^9.30.1",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.35.1",
    "vite": "^7.0.2",
    "vitest": "^3.2.4"
  }
}
